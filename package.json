{
  "name": "backend-finger",
  "version": "1.0.0",

  "description": "Backend system for managing campus attendance records.",
  "main": "src/server.ts",

  "scripts": {
    "start": "npx prisma db seed && node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:setup": "prisma db push && prisma db seed",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "db:import-today": "mysql -u root -pYOUR_DB_PASSWORD finger_db < seeds/insert_today_data.sql",
    "seed:device-mapping": "tsx scripts/seed-device-mapping.ts",
    "employee:add": "tsx scripts/add-new-employee.ts",
    "sync:attendance": "tsx scripts/sync-attendance.ts",
    "device:probe": "tsx scripts/probe.ts",
    "device:seed": "tsx scripts/seed-user.ts",
    "device:pull-seed": "tsx scripts/pull-and-seed.ts",
    "seed:holidays": "tsx scripts/seed-holidays.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\""
  },
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6",
    "@scalar/api-reference": "^1.43.8",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "ejs": "^4.0.1",
    "envalid": "^8.1.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.14.0",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.17.6",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prisma": "6",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.0"
  },
  "author": "Your Name",
  "license": "ISC",
  "keywords": [],
  "type": "commonjs"
}
