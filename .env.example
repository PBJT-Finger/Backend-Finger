# ============================================================
# Backend-Finger — Environment Configuration Template
# Salin file ini ke .env dan isi nilainya sebelum menjalankan server
# JANGAN commit file .env ke repository!
# ============================================================

# ----------------------------
# DATABASE (MySQL via Prisma)
# ----------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=finger_db
DB_USERNAME=root
DB_PASSWORD=your_db_password

# ----------------------------
# SERVER
# ----------------------------
# Port API backend — default: 3333
PORT=3333
NODE_ENV=development

# ----------------------------
# JWT AUTHENTICATION
# ----------------------------
# Minimal 32 karakter, buat dengan: openssl rand -base64 32
JWT_ACCESS_SECRET=your_jwt_access_secret_minimum_32_characters_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_32_characters_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------
# SECURITY
# ----------------------------
# Minimal 16 karakter
API_KEY_SECRET=your_api_key_secret_minimum_16_chars

# Daftar origin frontend yang diizinkan (pisahkan dengan koma, tanpa spasi)
# Finger-App berjalan di port 5555
CORS_ORIGINS=http://localhost:5555,http://localhost:3000

# ----------------------------
# LOGGING
# ----------------------------
LOG_LEVEL=info

# ----------------------------
# FINGERPRINT DEVICE (ZKTeco)
# ----------------------------
FINGERPRINT_IP=192.168.1.100
FINGERPRINT_PORT=4370

# ----------------------------
# EMAIL (SMTP) — Untuk fitur forgot password
# Jika tidak dipakai, biarkan kosong (server tetap jalan, email hanya ke console)
# ----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_SECURE=false       # true hanya untuk port 465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password     # ← nama ini harus SMTP_PASSWORD (bukan SMTP_PASS)
# EMAIL_FROM=noreply@fingerattendance.com
# EMAIL_FROM_NAME=Finger Attendance System

# ----------------------------
# DATABASE URL (Prisma — generate dari variabel di atas)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# ----------------------------
DATABASE_URL=mysql://root:your_db_password@localhost:3306/finger_db
